# Secrets — do not commit. Copy to secrets.yaml and fill in.

# Your Wi-Fi SSID and password
wifi_ssid: "your-wifi-ssid"
wifi_password: "your-wifi-password"
api_key: "generate with: openssl rand -base64 32"
ota_password: "ota-upload-password"

# Home MQTT broker (reached over Wi-Fi / LAN, via ESPHome's built-in mqtt stack)
mqtt_home_host: "192.168.1.10"
mqtt_home_user: "tracker"
mqtt_home_password: "home-broker-password"
# Optional broker TLS — paste the CA in PEM form and enable in esp-tracker.yaml:
# mqtt_home_ca: |
#   -----BEGIN CERTIFICATE-----
#   ...
#   -----END CERTIFICATE-----
